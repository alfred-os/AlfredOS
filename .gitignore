.github/agents/
.github/copilot-instructions.md
.github/hooks/
.github/prompts/
.github/skills/
.goosehints
.junie/
.kilo/
kilo.jsonc
.kiro/
.opencode/
.opencode.json
opencode.jsonc
.pi/
.qoder/
QODER.md
.qwen/
QWEN.md
.roo/
.rovodev/
.takt/
.windsurf/
