# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# uv
.uv/

# Local environment
.env
.env.*
!.env.example

# Docker / runtime state — never commit. The negations below exempt
# the in-tree ``src/alfred/state/`` Python package (ADR-0018 — typed
# state.git proposal payloads) and the matching
# ``tests/integration/state/`` round-trip suite; the runtime state.git
# store at ``/var/lib/alfred/state.git`` and any developer-mounted
# ``./state/`` bind volume still matches.
state/
!src/alfred/state/
!tests/integration/state/
data/
*.db
*.sqlite*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Build artifacts
dist/
build/

# pytest-benchmark JSON dump (produced by `make test-perf` for CI artifact
# upload; harmless locally but never tracked).
benchmark.json

# AI-tool-specific outputs are generated from .rulesync/ via `rulesync generate`.
# Source of truth lives in .rulesync/. All AI-tool outputs (root-level CLAUDE.md
# and AGENTS.md included) are generated by `rulesync generate` and gitignored;
# the canonical content lives in .rulesync/rules/CLAUDE.md. Run
# `rulesync generate -t '*' -f '*'` after cloning to populate locally.
.memsearch/
.claude/
.mcp.json
CLAUDE.md
AGENTS.md
.github/copilot-instructions.md
.gemini/
GEMINI.md
# Other AI tool outputs (uncomment / add if you start generating them locally)
# .cursorrules
# .cursor/
# .clinerules

# Secrets — never commit; see ADR-0012. The file-backed SecretBroker reads
# from ~/.config/alfred/secrets.toml (host) or /etc/alfred/secrets.toml
# (container); test fixtures that synthesise the production filename are
# caught by the third `**` pattern even when nested under tests/.
secrets.toml
secrets.*.toml
**/secrets.toml
