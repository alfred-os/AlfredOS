# Discord-adapter bwrap sandbox policy (Linux) — PR-S4-9, spec §7.9, ADR-0015/ADR-0016.
#
# This is the REAL OS-isolation policy the launcher resolves for the
# `alfred.discord` plugin (manifest `[sandbox] kind = "full"`,
# `[sandbox.policy_refs] linux = ...`). It is parsed by `read_policy_toml`
# into a `SandboxPolicy` and translated by `policy_to_bwrap_flags` into the
# bwrap CLI flag list the launcher execs (see
# `src/alfred/plugins/sandbox_policy.py`).
#
# Threat model. The Discord adapter ingests adversary-controlled bytes from
# ARBITRARY Discord users — embed titles, attachment filenames, message
# content, reply targets. Any one of those is an injection vector. The PR #205
# round-2 sec-1 closure dropped the first-party-relay `kind: none` carve-out:
# the cost of bwrap is acceptable given the surface. The plugin opens its
# Discord WSS connection INSIDE this sandbox. A compromise in the event-parsing
# path (a crafted gateway frame triggering a discord.py / parser bug) must NOT
# escalate beyond the kernel-enforced containment below.
#
# Relationship to the quarantined-LLM policy. This policy MIRRORS
# `quarantined-llm.linux.bwrap.policy` structurally — same fs/namespace
# containment, same fd-3 broker channel, same documented egress gap — with ONE
# deliberate addition: the Discord adapter needs outbound TLS to the Discord
# gateway, so it ro-binds `/etc/ssl/certs` (the system CA bundle) which the
# quarantined LLM does not. See the cert-bind note below.
#
# ----------------------------------------------------------------------------
# Filesystem confinement
# ----------------------------------------------------------------------------
# Read-only binds for the interpreter + its shared libraries ONLY, plus the
# system CA bundle. We bind the usrmerged system trees (/usr, /lib — plus /lib64
# SOFTLY, see the arch note on `ro_binds_try` below) read-only so CPython +
# discord.py can exec and dynamically link, and NOTHING else:
#
#   * NO /etc bind (other than the explicit /etc/ssl/certs read below) —
#     /etc/passwd, /etc/shadow, ssh configs, the host's secrets-in-config all
#     stay invisible.
#   * /etc/ssl/certs IS bound read-only. SECURITY-RELEVANT DIFFERENCE from the
#     quarantined-LLM policy: the Discord plugin establishes a TLS (WSS)
#     connection to `gateway.discord.gg` and a REST connection to
#     `discord.com/api`; verifying the server certificate chain requires the
#     system CA bundle. Binding ONLY `/etc/ssl/certs` (not all of /etc) keeps
#     host account/secret material invisible while letting TLS verification
#     succeed. This is the minimal cert surface — no `/etc/ssl/private`, no
#     openssl config, no other /etc path.
#   * NO /bin bind — on usrmerged Linux /bin is a symlink to /usr/bin; the
#     PRIMARY exec containment is `--unshare-pid` + `--die-with-parent` + the
#     empty writable surface. Tightening the interpreter bind to the exact
#     CPython prefix (dropping the broad /usr) is tracked in #230.
ro_binds = [
  ["/usr", "/usr"],
  ["/lib", "/lib"],
  ["/etc/ssl/certs", "/etc/ssl/certs"],
]

# SOFT read-only bind (#269) — bound iff the source EXISTS, else skipped
# (`--ro-bind-try`). `/lib64` holds the dynamic linker on x86-64
# (`ld-linux-x86-64.so.2`) but does NOT exist on arm64, where the loader is
# `/lib/ld-linux-aarch64.so.1` — already covered by the `/lib` bind above. A
# HARD `--ro-bind /lib64` kills the sandbox launch on aarch64 (`bwrap: Can't
# find source path /lib64`), so the adapter child never starts. Soft-binding it
# makes these SAME policy bytes portable across both arches.
#
# `/etc/ssl/certs` deliberately stays a HARD bind above: it is NOT arch-variable,
# and an adapter that silently lost its CA bundle would fail TLS to the Discord
# gateway at runtime instead of failing loud at launch. Only genuinely
# arch-variable paths belong here.
ro_binds_try = [
  ["/lib64", "/lib64"],
]

# A single writable scratch directory, backed by an ephemeral tmpfs that dies
# with the sandbox. The Discord plugin needs a place for its on-disk
# idempotency store + scratch; this gives it one with NO host-filesystem reach.
# The tmpfs is fresh per launch and discarded on exit — nothing the plugin
# writes survives or leaks onto the host.
tmpfs = ["/run/alfred/discord"]

# A synthesised minimal /dev (null/zero/full/random/urandom/tty) — NOT the
# host's /dev (no device passthrough). Required: CPython aborts at startup
# without /dev/urandom (`_Py_HashRandomization_Init`).
dev = true

# Namespace isolation. We unshare:
#   * pid    — the sandboxed process cannot see or signal host PIDs, and
#              `--die-with-parent` reaps the whole subtree when the Supervisor
#              exits. This is the load-bearing process-fork/exec containment.
#   * uts    — its own hostname; cannot read the host's.
#   * cgroup — cannot observe/escape the host cgroup hierarchy.
#   * ipc    — cannot reach host System V IPC / POSIX shm.
#   * net    — empty network namespace; the sandbox has NO network access.
#              G7-4 / ADR-0043: all outbound egress routes through the
#              bind-mounted gateway L7 CONNECT proxy socket at
#              /home/alfred/.egress/discord/egress.sock (see rw_binds below).
unshare = ["pid", "uts", "cgroup", "ipc", "net"]

# Reap the sandbox subtree when the Supervisor process exits — no orphaned
# Discord plugin can outlive its parent and keep relaying T3 content.
die_with_parent = true

# fd 3 carries the Supervisor's broker channel (the plugin fetches
# `discord_bot_token` over the broker at lifecycle.start; the broker substitutes
# at the JSON-RPC boundary so the raw token never lands in env/argv). fd 3 is
# inherited by default (NO CLI flag — see the `policy_to_bwrap_flags` docstring
# + #218). `keep_fds` is the validated DECLARATION that fd 3 must survive;
# omitting it is refused at parse time (`kind_full_requires_keep_fd_3`).
keep_fds = [3]

# ============================================================================
# Egress containment — G7-4 enforced (ADR-0043, closes #230)
# ============================================================================
# The Discord plugin's outbound network is now kernel-enforced:
#
#   * `--unshare-net` (the "net" entry above) gives the sandbox an EMPTY
#     network namespace — ONLY loopback (bwrap brings lo up); no host network,
#     no raw-socket access to external hosts. The in-child shim binds 127.0.0.1
#     (loopback) so discord.py's proxy URL resolves; egress to any non-loopback
#     destination fails at the kernel. A compromised Discord plugin CANNOT open
#     an arbitrary outbound connection.
#
#   * The ONLY egress path is the bind-mounted gateway L7 CONNECT forward-proxy
#     socket at /home/alfred/.egress/discord/egress.sock (rw-bound below).
#     discord.py is configured (G7-4) to route all WSS + REST calls through this
#     proxy. The gateway enforces the Discord-only destination allowlist:
#     only `gateway.discord.gg` and `discord.com` may be connected to.
#
#   * `connect(2)` to any other host, or any raw-socket attempt, is refused at
#     the kernel (empty netns) — not just at the proxy layer. This is the G7-4
#     closure of the egress gap that was documented as deferred in pre-G7-4
#     policy versions. See ADR-0043 for the full design rationale.
# ============================================================================

# Egress socket directory — rw-bind (--bind, NOT --ro-bind). connect(2) on a
# UNIX-domain socket path requires write permission on the socket file; a
# read-only bind fails with EACCES (FIX-5). The gateway-only socket dir is
# the SOLE network surface mounted into the sandbox; the host netns remains
# invisible behind the --unshare-net kernel boundary.
rw_binds = [
  ["/home/alfred/.egress/discord", "/home/alfred/.egress/discord"],
]
