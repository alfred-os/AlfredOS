# Quarantined-LLM bwrap sandbox policy (Linux) — PR-S4-7, spec §7.2, ADR-0015.
#
# This is the REAL OS-isolation policy the launcher resolves for the
# `alfred.quarantined-llm` plugin (manifest `[sandbox] kind = "full"`,
# `[sandbox.policy_refs] linux = ...`). It is parsed by `read_policy_toml`
# into a `SandboxPolicy` and translated by `policy_to_bwrap_flags` into the
# bwrap CLI flag list the launcher execs (see
# `src/alfred/plugins/sandbox_policy.py`).
#
# Threat model. The quarantined LLM is the ONLY component that touches raw
# T3 (untrusted) content — adversary-controlled web pages, emails, RAG
# snippets, tool outputs. A compromise in the provider-response-parsing path
# (e.g. a crafted streamed response triggering a parser bug) must NOT escalate
# beyond the kernel-enforced sandbox. Everything below is the containment the
# kernel enforces around that subprocess.
#
# ----------------------------------------------------------------------------
# Filesystem confinement
# ----------------------------------------------------------------------------
# Read-only binds for the interpreter + its shared libraries ONLY. We bind the
# usrmerged system trees (/usr, /lib — plus /lib64 SOFTLY, see the arch note on
# `ro_binds_try` below) read-only so CPython can exec and dynamically link, and
# NOTHING else:
#
#   * NO broad /etc bind, with ONE narrow, deliberate carve-out — see below.
#     /etc/passwd, /etc/shadow, resolv.conf, ssh configs, the host's
#     secrets-in-config all stay invisible; the ONLY /etc subpath bound into
#     this sandbox is /etc/ssl/certs (the public-CA trust store, see the
#     `ro_binds` list below), needed for the golive child's in-child TLS
#     verify against its brokered gateway socket (#340). That path carries no
#     host secret — it is the same public root-CA bundle every TLS client on
#     the host reads, and it is bound READ-ONLY at the exact subpath, never a
#     bare `/etc` bind (the #428 over-broad-bind class this repo has fixed
#     before: a bare `/etc` bind would additionally expose /etc/passwd,
#     /etc/shadow, resolv.conf and ssh configs — none of that rides in on this
#     carve-out). An adversary that owns the T3 response still cannot read a
#     host /etc/passwd, /etc/shadow, or resolv.conf to learn usernames,
#     credentials, or the DNS posture for a follow-on attack.
#   * NO /bin bind — on usrmerged Linux /bin is a symlink to /usr/bin, so we
#     deliberately do NOT bind it separately; /bin/sh / /usr/bin/env are NOT
#     reachable as exec targets from inside (process-exec containment, below).
#     NB: /usr/bin IS under the /usr bind, so a determined exec of an absolute
#     /usr/bin path could still find a binary — the PRIMARY exec containment is
#     `--unshare-pid` + `--die-with-parent` + the empty writable surface, and
#     the kernel-observable adversarial corpus asserts the practical
#     containment (no host /etc read, no new long-lived child escaping the pid
#     namespace). Tightening the interpreter bind to the exact CPython prefix
#     (dropping the broad /usr) is tracked in #230.
ro_binds = [
  ["/usr", "/usr"],
  ["/lib", "/lib"],
  # The narrow CA carve-out (#340 golive) — see the note above. HARD, not
  # soft: /etc/ssl/certs is not arch-variable (present on every supported
  # Linux target), so a missing source here must fail the launch LOUD rather
  # than silently degrade the sandbox's TLS-verify path (the schema's own
  # `_restrict_soft_binds` validator refuses this exact path from
  # `ro_binds_try` for the same reason). This is the ONLY /etc subpath bound
  # anywhere in this policy.
  ["/etc/ssl/certs", "/etc/ssl/certs"],
]

# SOFT read-only bind (#269) — bound iff the source EXISTS, else skipped
# (`--ro-bind-try`). `/lib64` holds the dynamic linker on x86-64
# (`ld-linux-x86-64.so.2`) but does NOT exist on arm64, where the loader is
# `/lib/ld-linux-aarch64.so.1` — already covered by the `/lib` bind above. A
# HARD `--ro-bind /lib64` therefore kills the sandbox launch on aarch64
# (`bwrap: Can't find source path /lib64`): the quarantined child never starts,
# never emits a frame, and the host surfaces a truncated `read_frame_failed`.
# Soft-binding it makes these SAME policy bytes portable across both arches.
#
# This does NOT weaken containment: the mount stays read-only where it exists,
# and a path that does not exist was never reachable from inside the sandbox.
# Only genuinely ARCH-VARIABLE paths belong here — `/usr` and `/lib` stay HARD
# above, because a missing one is a real error that must fail loud rather than
# silently degrade into a broken sandbox.
ro_binds_try = [
  ["/lib64", "/lib64"],
]

# A single writable scratch directory, backed by an ephemeral tmpfs that dies
# with the sandbox. The quarantined LLM needs a place to spool a streamed
# response / scratch file; this gives it one with NO host-filesystem reach. The
# tmpfs is fresh per launch and discarded on exit — nothing the quarantined
# process writes survives or leaks onto the host.
tmpfs = ["/run/alfred/quarantined"]

# A synthesised minimal /dev (null/zero/full/random/urandom/tty) — NOT the
# host's /dev (no device passthrough). Required: CPython aborts at startup
# without /dev/urandom (`_Py_HashRandomization_Init`).
dev = true

# Namespace isolation. We unshare:
#   * pid    — the sandboxed process cannot see or signal host PIDs, and
#              `--die-with-parent` reaps the whole subtree when the Supervisor
#              exits. This is the load-bearing process-fork/exec containment.
#   * uts    — its own hostname; cannot read the host's.
#   * cgroup — cannot observe/escape the host cgroup hierarchy.
#   * ipc    — cannot reach host System V IPC / POSIX shm.
#   * net    — Spec C G7-1 (#333): an EMPTY network namespace. The shipped child
#              runs a DETERMINISTIC ECHO loop (no provider client, no socket), so
#              it needs ZERO egress; `--unshare-net` closes the #230 egress hole
#              for it at the kernel. The 2c real-LLM child (separate follow-on,
#              still #230) reaches its provider PROVIDER-ONLY via the gateway L7
#              CONNECT proxy — NOT by re-opening this namespace. SECURITY-CRITICAL:
#              read the egress note below before dropping `net`.
unshare = ["pid", "uts", "cgroup", "ipc", "net"]

# Reap the sandbox subtree when the Supervisor process exits — no orphaned
# quarantined process can outlive its parent and keep running with T3 content.
die_with_parent = true

# fd 3 carries the Supervisor's provider-key channel (arch-2). The shipped
# deterministic-echo child does NOT make a provider call (it `--unshare-net`s,
# below) and does not consume the key; the fd-3 channel is retained as the
# stable substrate the 2c real-LLM child will use to receive the key, and the
# 2c provider HTTPS call goes through the gateway L7 CONNECT proxy (Spec C, #230),
# never by re-opening this child's network namespace. fd 3 arrives over the
# inherited descriptor (NO CLI flag — see the `policy_to_bwrap_flags` docstring +
# #218); `keep_fds` is the validated DECLARATION that fd 3 must survive — omitting
# it is refused at parse time (`kind_full_requires_keep_fd_3`).
#
# fd 4 carries the SCM_RIGHTS control channel (#340 golive): the host passes a
# broker-connected gateway socket into the sandbox over fd 4 (ancillary data on
# a UNIX-domain socket, `egress/control_fd_broker.py`), and the golive
# child reconstructs it and terminates TLS in-child against that socket — the
# `ro_binds` CA carve-out above is what makes that TLS verify possible. Like fd
# 3, fd 4 arrives over the inherited descriptor (bwrap's default fd inheritance
# for open, non-CLOEXEC fds — no CLI flag is emitted, same as fd 3); adding it
# to `keep_fds` is the same validated DECLARATION discipline, extended to the
# second channel.
keep_fds = [3, 4]

# ============================================================================
# EGRESS IS CLOSED for the shipped echo child (Spec C G7-1, #333)
# ============================================================================
# The shipped quarantined-LLM child runs a DETERMINISTIC ECHO loop with NO
# provider client and NO socket of its own (the import-graph invariant in
# `tests/adversarial/sandbox_escape/test_quarantined_llm_not_yet_spawned_while_egress_open.py`
# keeps it honest). It therefore needs ZERO outbound network, so `unshare`
# now includes `net`: the child runs in an EMPTY network namespace. Even a
# compromised echo child cannot open an outbound connection — there is no
# network namespace to connect from. This closes the #230 egress hole for the
# component that exists today; `sbx-2026-005` flips from `out_of_scope` to an
# enforced-containment payload accordingly.
#
# STILL #230 — the 2c real-LLM child (a separate follow-on) DOES make a provider
# call and needs egress. It will NOT re-open this namespace: it reaches the
# provider endpoint PROVIDER-ONLY through the gateway L7 CONNECT proxy (the core
# is connectivity-free; the gateway is the sole external I/O plane — Spec C). The
# unset-provider-key boot guard + the real egress wiring land with 2c, behind the
# `#230` release-blocker. Dropping `net` from the unshare set above would silently
# re-open this child's egress and is refused by the closed-egress anchor gate.
# ============================================================================
