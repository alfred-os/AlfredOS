"No operator has been added yet. Run 'alfred user add --authorization "
"operator --name <YourName>' first."

#: src/alfred/comms/discord.py:112
msgid "discord.embed_unsupported"
msgstr ""
"I can only read text DMs in Slice 2. Embeds, attachments, polls, "
"components, stickers, and references are refused."

#: src/alfred/comms/discord.py:113
msgid "discord.rate_limited"
msgstr "You're sending messages faster than I can keep up. Try again in a moment."

#: src/alfred/comms/discord.py:617 src/alfred/comms/discord.py:780
#: src/alfred/comms/discord.py:786 src/alfred/comms/discord.py:916
#: src/alfred/comms/discord.py:936 src/alfred/comms/discord.py:963
msgid "discord.alfred_error"
msgstr "Something went wrong on my end. The operator's audit log has the details."

# PR D2 — Discord adapter i18n catalog (spec §3 lines 514-520).
#: src/alfred/comms/discord.py:689
msgid "discord.unknown_user_first"
msgstr ""
"I don't recognise this Discord ID yet (snowflake: `{snowflake}`). Ask "
"your operator to run: `alfred user add --name <YourName> --discord-id "
"{snowflake}`. The operator's audit log shows this DM."

#: src/alfred/comms/discord.py:768
msgid "discord.budget_blocked"
msgstr "Daily budget reached ({spent} of {cap} USD). Resets at UTC midnight."

