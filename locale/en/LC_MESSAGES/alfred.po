msgstr ""
"No allowlist entries to display. The web_allowlist projection is empty "
"(no operator-added entries yet, or the Postgres projection is not yet "
"wired — PR-S3-7)."

#: src/alfred/cli/web.py:259
msgid "cli.web.allowlist.list.column.domain"
msgstr "domain"

#: src/alfred/cli/web.py:260
msgid "cli.web.allowlist.list.column.path_prefix"
msgstr "path_prefix"

#: src/alfred/cli/web.py:261
msgid "cli.web.allowlist.list.column.granted_by"
msgstr "granted_by"

#: src/alfred/cli/web.py:262
msgid "cli.web.allowlist.list.column.granted_at"
msgstr "granted_at"

#: src/alfred/cli/web.py:292
msgid "cli.web.allowlist.add.denied"
msgstr "alfred web allowlist add denied: {reason}"

#: src/alfred/cli/web.py:293
msgid "cli.web.allowlist.add.pending_review"
msgstr ""
"Allowlist-add proposal queued for reviewer approval.\n"
"  branch:       {branch}\n"
"  proposal_id:  {proposal_id}\n"
"The domain is NOT yet fetchable — it activates when the reviewer approves"
