# Slice-3 retrospective fix DEVEX-001 — bare i18n keys emitted by
# bin/alfred-plugin-launcher.sh on stderr. The supervisor renders these
# from the catalog when persisting the matching audit row. The keys
# themselves stay as the machine-readable stderr signal; these msgstrs
# are the human-readable rendering.
# CR-142 round-3 doc-001: promoted from obsolete (#~) to active msgids
# via _launcher_i18n.py so pybabel extract sees them and they survive
# every ``pybabel update`` pass. Without the registry module, pybabel
# re-marks them ``#~`` on every sync (the launcher emits them from a
# shell script that pybabel cannot parse).
#: src/alfred/plugins/_launcher_i18n.py:36
msgid "plugin.launcher_plugin_id_invalid"
msgstr ""
"Plugin spawn refused: the supplied plugin_id contained characters outside"
" the safe charset [A-Za-z0-9._-]. The id is not echoed (it would round-"
"trip into the audit stream)."

#: src/alfred/plugins/_launcher_i18n.py:37
msgid "plugin.launcher_unsandboxed_rejected"
msgstr ""
"Plugin spawn refused: ALFRED_PLUGIN_LAUNCHER_UNSANDBOXED=1 is a "
"development-only escape hatch and was supplied outside development. Unset"
" the flag or set ALFRED_ENV=development (never in production)."

#: src/alfred/plugins/_launcher_i18n.py:38
msgid "plugin.launcher_no_sandbox_policy"
msgstr ""
"Plugin spawn refused: no sandbox policy file at "
"${{ALFRED_SANDBOX_POLICY_DIR}}/{plugin_id}.policy. Provision the policy "
"file (see docs/runbooks/slice-3-plugins.md) or, for development only, set"
" ALFRED_ENV=development + ALFRED_PLUGIN_LAUNCHER_UNSANDBOXED=1."

#: src/alfred/plugins/_launcher_i18n.py:39
msgid "plugin.launcher_uid_drop_unavailable"
msgstr ""
"Plugin spawn refused: runuser is missing on this Linux host so the "
"launcher cannot drop privilege to ${{ALFRED_PLUGIN_UID}} before exec. "
"Install util-linux and retry."

# Supervisor.config_insecure JSON events the launcher emits on
# documented-deviation paths. The insecure_config_key is the
# closed-vocabulary identifier the supervisor matches; the msgstr
# is the operator-facing renderer.
#: src/alfred/plugins/_launcher_i18n.py:40
msgid "plugin.launcher_insecure_unsandboxed_dev"
msgstr ""
"Plugin {plugin_id} spawned WITHOUT a sandbox policy "
"(ALFRED_PLUGIN_LAUNCHER_UNSANDBOXED=1 + ALFRED_ENV=development). This is "
"a documented dev-only deviation; MUST NOT appear in production logs."

#: src/alfred/plugins/_launcher_i18n.py:42
msgid "plugin.launcher_insecure_uid_separation_macos"
msgstr ""
"Plugin {plugin_id} spawned WITHOUT UID separation (macOS dev host; "
"runuser is Linux-only). Documented dev-only deviation; MUST NOT appear in"
" production logs."

#: src/alfred/plugins/content_store_base.py:153
msgid "plugin.content_store.inmemory_not_production_safe"
msgstr ""
"InMemoryContentStore is not production-safe (ALFRED_ENV={env}); inject a "
"Redis-backed ContentStore via StdioTransport(content_store=...) or set "
"ALFRED_ENV to development or test for stub usage."

