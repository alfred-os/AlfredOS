#: src/alfred/cli/plugin.py:563
msgid "cli.plugin.revoke.denied"
msgstr "alfred plugin revoke denied: {reason}"

#: src/alfred/cli/plugin.py:564
msgid "cli.plugin.revoke.pending_review"
msgstr ""
"Revocation proposal queued for reviewer approval.\n"
"  branch:       {branch}\n"
"  proposal_id:  {proposal_id}\n"
"The revocation is NOT yet effective — it activates when the reviewer "
"approves the proposal."

# PR-S3-6 Component E — alfred supervisor sub-app (status read-only,
# reset --confirm gate). T1-tier per spec §10.8.
#: src/alfred/cli/supervisor.py:38
msgid "cli.supervisor.help"
msgstr ""
"Inspect supervised components, queue circuit-breaker resets for reviewer "
"approval, and audit recent dispatch results."

# CR-156 round-7 BLOCKER #4: ProgrammingError from the read path means
# the schema is not initialised (``circuit_breakers`` does not exist).
# Routes to a dedicated key naming the remediation rather than dumping
# a raw SQLAlchemy traceback at an operator.
#: src/alfred/cli/supervisor.py:476 src/alfred/cli/supervisor.py:941
msgid "cli.supervisor.status.schema_not_initialised"
msgstr ""
"Database schema not initialised. Run: alfred-stack migrate (or `alembic "
"upgrade head` inside the alfred container). If migrations have run, the "
"circuit_breakers table is missing — flag in #134."

# CR-156 round-7 MEDIUM #10: enumerate the operator recovery levers
# (stack-down vs URL-wrong vs auth-failed vs restarting) so the hint
# names a concrete action for each common cause rather than collapsing
# everything to "check the stack".
#: src/alfred/cli/supervisor.py:483 src/alfred/cli/supervisor.py:492
#: src/alfred/cli/supervisor.py:944
msgid "cli.supervisor.status.postgres_unavailable"
msgstr ""
"Cannot reach the Alfred Postgres database.\n"
"\n"
"Common causes (operator action):\n"
"  - Stack down: docker compose ps; docker compose up -d alfred-postgres\n"
"  - DATABASE_URL points at the wrong host/database\n"
"  - Credentials wrong (auth failed): check the value of DATABASE_URL\n"
"  - Postgres restarting / shutting down (retry in a few seconds)\n"
"\n"
"If none of the above, check the supervisor logs for the underlying\n"
"SQLSTATE class."

#: src/alfred/cli/supervisor.py:495
msgid "cli.supervisor.status.no_components_yet"
msgstr ""
"No supervised components registered yet. The supervisor writes the first "
"row to the `circuit_breakers` table when a plugin loads — wait for the "
"orchestrator to boot a component, then re-run `alfred supervisor status`."

#: src/alfred/cli/supervisor.py:525
msgid "cli.supervisor.status.column.state"
msgstr "STATE"

#: src/alfred/cli/supervisor.py:526
msgid "cli.supervisor.status.column.trip_count"
msgstr "TRIP COUNT"

#: src/alfred/cli/supervisor.py:529 src/alfred/cli/supervisor.py:544
msgid "cli.supervisor.status.column.component"
msgstr "COMPONENT"

#: src/alfred/cli/supervisor.py:538 src/alfred/cli/supervisor.py:547
msgid "cli.supervisor.status.column.last_trip_at"
msgstr "LAST TRIP"

# CR-156 round-7 MEDIUM #14: freshness footer printed after the status
# table. Surfaces the staleness model inline so operators don't need
# to consult the runbook to know how current the data is.
#: src/alfred/cli/supervisor.py:579
msgid "cli.supervisor.status.freshness_footer"
msgstr ""
"Snapshot reflects the supervisor's last save_to_db write (typically <=1 "
"cycle stale). See docs/runbooks/slice-3-supervisor.md."

# CR rework round-1 HIGH #12: emitted when ``_render_dispatch_footer``
# narrows on ``OperationalError`` / ``ProgrammingError`` — Postgres
# unreachable OR schema not initialised. The primary status surface
# (the breaker table) already rendered, so we surface the footer's
# unavailability instead of crashing the whole status command.
#: src/alfred/cli/supervisor.py:603
msgid "cli.supervisor.status.dispatch_footer_unavailable"
msgstr ""
"Recent proposal dispatch (last hour): unavailable. Check supervisor logs "
"for the underlying error."

# ADR-0021 #171 Operator visibility: footer reporting last-hour
# dispatch outcomes. Renders even when every count is zero so the
# absence of activity is the answer, not a missing surface. CR
# rework round-1 HIGH #11: the hardcoded ``{pending}`` placeholder
# was always 0 (the loop is monotonically forward — a merged blob
# either appears in the ledger or has not yet been walked); dropped
# until a meaningful pending-count surface lands.
#: src/alfred/cli/supervisor.py:612
msgid "cli.supervisor.status.dispatch_footer"
msgstr "Recent proposal dispatch (last hour): {applied} applied, {failed} failed."

# ADR-0021 #171: the reset command's docstring documents operator
# intent for code readers; this key surfaces on the `--help` operator
# surface. The deferred-to-#171 stopgap is tombstoned now that the
# dispatcher ships in the same PR.
#: src/alfred/cli/supervisor.py:619
msgid "cli.supervisor.reset.help.short"
msgstr "Reset a circuit breaker. Writes a reviewer-gated state.git proposal."

#: src/alfred/cli/supervisor.py:621
msgid "cli.supervisor.reset.usage"
msgstr "Component id (e.g. quarantined-llm) whose circuit breaker to reset."

# ADR-0021 #171: ``--confirm`` regains its gating semantic. Reset now
# writes a real state.git proposal (the no-op stopgap from #154 was
# only justified while the underlying reset was deferred), so explicit
# confirmation is meaningful again.
#: src/alfred/cli/supervisor.py:631
msgid "cli.supervisor.reset.confirm_help"
msgstr ""
"Required: confirm the reset request. Writes a reviewer-gated state.git "
"proposal; the supervisor applies the reset on the next dispatch cycle."

# ADR-0021 #171: emitted when --confirm is absent. The flag is now a
# real gate (partial revert of #154 BLOCKER #6 no-op semantic) because
# the underlying reset performs actual state mutation.
#: src/alfred/cli/supervisor.py:665
msgid "cli.supervisor.reset.confirm_required"
msgstr ""
"alfred supervisor reset requires --confirm to write the state.git "
"proposal. Re-run with --confirm to queue the reset for reviewer approval."

#: src/alfred/cli/supervisor.py:729
msgid "cli.supervisor.reset.denied"
msgstr "alfred supervisor reset denied: {reason}"

#: src/alfred/cli/supervisor.py:731
msgid "cli.supervisor.reset.proposal_submitted"
msgstr ""
"Circuit-breaker reset for {component} queued for reviewer approval.\n"
"  branch:       {branch}\n"
"  proposal_id:  {proposal_id}\n"
"The supervisor applies the reset on the next dispatch cycle (up to "
"{interval}s after reviewer merge — requires the daemon boot path #174 to "
"be wired).\n"
"Check dispatch status with: alfred supervisor proposals --since 1h"

# CR-rework round-2 follow-up: localise the two parser-error messages
# emitted from :func:`_parse_duration` so the operator-facing surface
# stays consistent across locales (CLAUDE.md i18n hard rule #1).
#: src/alfred/cli/supervisor.py:875
msgid "cli.supervisor.proposals.since_invalid"
msgstr ""
"Invalid --since value: {value}. Expected a unit-suffixed duration like "
"{example}."

#: src/alfred/cli/supervisor.py:882
msgid "cli.supervisor.proposals.since_must_be_positive"
msgstr "Invalid --since value: {value}. Duration must be positive."

# ADR-0021 #171: ``alfred supervisor proposals`` subcommand. Lists
# recently-processed state.git side-effecting dispatch outcomes; the
# canonical operator surface for "what did the dispatcher do?".
#: src/alfred/cli/supervisor.py:886
msgid "cli.supervisor.proposals.help.short"
msgstr "List recent state.git side-effecting dispatch results."

# CR rework round-1 HIGH #13: ``--since DURATION`` replaces the
# binary ``--recent`` flag so operators can scope to arbitrary
# windows (1h / 24h / 7d). Default 1h preserves the previous
# ``--recent`` semantic.
#: src/alfred/cli/supervisor.py:892
msgid "cli.supervisor.proposals.since_help"
msgstr ""
"Scope to dispatches processed within DURATION (e.g. 1h, 24h, 7d). Default"
" 1h."

# CR rework round-1 HIGH #13: paginate the listing. ``--all`` is
# the escape hatch when an operator wants every row in the ledger
# (e.g. forensic export).
#: src/alfred/cli/supervisor.py:899
msgid "cli.supervisor.proposals.limit_help"
msgstr "Maximum rows to render. Default 20. Ignored when --all is passed."

#: src/alfred/cli/supervisor.py:907
msgid "cli.supervisor.proposals.all_help"
msgstr "Render every row in the ledger; ignores --limit and --since."

# CR-rework round-2 follow-up: ``--all`` disables the time filter, so
# the ``--since`` window text from ``empty`` would mislead the
# operator. Distinct empty-state body omits the window.
#: src/alfred/cli/supervisor.py:958
msgid "cli.supervisor.proposals.empty_all"
msgstr ""
"No proposals to display. The supervisor's dispatch loop polls every "
"{interval}s; re-run after the next cycle if a proposal has just merged."

# CR rework round-1 HIGH #13: empty-state body includes the
# dispatch-cycle interval so the operator knows how long to wait
# before re-checking after a proposal merges.
#: src/alfred/cli/supervisor.py:962
msgid "cli.supervisor.proposals.empty"
msgstr ""
"No proposals to display in the {since} window. The supervisor's dispatch "
"loop polls every {interval}s; re-run after the next cycle if a proposal "
"has just merged."

#: src/alfred/cli/supervisor.py:970
msgid "cli.supervisor.proposals.column.proposal_type"
msgstr "TYPE"

#: src/alfred/cli/supervisor.py:971
msgid "cli.supervisor.proposals.column.proposal_id"
msgstr "ID"

#: src/alfred/cli/supervisor.py:972
msgid "cli.supervisor.proposals.column.result"
msgstr "RESULT"

#: src/alfred/cli/supervisor.py:973
msgid "cli.supervisor.proposals.column.failure_kind"
msgstr "FAILURE"

#: src/alfred/cli/supervisor.py:974
msgid "cli.supervisor.proposals.column.operator_user_id"
msgstr "OPERATOR"

#: src/alfred/cli/supervisor.py:975
msgid "cli.supervisor.proposals.column.processed_at"
msgstr "PROCESSED AT"

# CR rework round-1 HIGH #13: closed-vocab legend for the ``result``
# column. Helps operators decode the four values without consulting
# the runbook on the on-call channel.
#: src/alfred/cli/supervisor.py:992
msgid "cli.supervisor.proposals.legend"
msgstr ""
"Result values: applied (handler ran cleanly), failed_handler (handler "
"reported error — see failure_kind), failed_parse (proposal blob "
"unreadable), failed_unknown_type (path prefix not registered)."

# PR-S3-6 Component C — alfred web allowlist sub-app (reviewer-gated
# add/remove, read-only list). Async-UX strings carry {branch} +
# {proposal_id} so the operator can copy-paste the follow-up command.
#: src/alfred/cli/web.py:84
msgid "cli.web.help.group"
msgstr "Manage web-fetch policy (domain allowlist, per-domain limits)."

#: src/alfred/cli/web.py:89
msgid "cli.web.allowlist.help.group"
msgstr "Manage the web-fetch domain allowlist."

#: src/alfred/cli/web.py:113
msgid "cli.web.allowlist.add.help.short"
