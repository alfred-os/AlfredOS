# PR-S3-6 Component B — alfred plugin sub-app (reviewer-gated grant/revoke,
# read-only list/show/status). Async-UX strings carry {branch} +
# {proposal_id} so the operator can copy-paste the follow-up command.
#: src/alfred/cli/plugin.py:127
msgid "cli.plugin.help.group"
msgstr "Manage plugin grants and inspect loaded plugins."

#: src/alfred/cli/plugin.py:206
msgid "cli.plugin.grant.follow_up_command"
msgstr "Check status with: alfred plugin grant status {proposal_id}"

#: src/alfred/cli/plugin.py:215
msgid "cli.plugin.grant.list_pending_hint"
msgstr "See all queued grants with: alfred plugin grant list --pending"

#: src/alfred/cli/plugin.py:244
msgid "cli.plugin.grant.help.short"
msgstr "Queue a reviewer-gated capability-grant proposal for a plugin."

#: src/alfred/cli/plugin.py:251
msgid "cli.plugin.grant.arg.plugin_id"
msgstr "Plugin id from the manifest (e.g. alfred.web-fetch)."

#: src/alfred/cli/plugin.py:307
