#: src/alfred/plugins/web_fetch/errors.py:204
msgid "security.canary_tripped"
msgstr ""
"SECURITY: canary token detected in content from {url!r}; the plugin "
"subprocess has been quarantined."

#: src/alfred/plugins/web_fetch/content_store.py:105
msgid "web.fetch.error.content_handle_expired"
msgstr ""
"web.fetch content handle {handle_id!r} has expired or was already "
"extracted."

#: src/alfred/plugins/web_fetch/errors.py:51
msgid "web.fetch.error.domain_not_allowed"
msgstr ""
"web.fetch refused: domain {domain!r} is not in the effective allowlist "
"(manifest ∩ operator config ∩ per-session)."

# CR-146 major: ``redirect_target`` is attacker-controlled (the upstream
# Location header) and must NOT appear in the caller-visible message —
# leaking it back hands SSRF forensics to the requester. Full target
# stays on WebFetchRedirectRefused.redirect_target for the audit row.
#: src/alfred/plugins/web_fetch/errors.py:83
msgid "web.fetch.error.redirect_refused"
msgstr ""
"web.fetch refused: upstream returned HTTP {status_code} redirect. SSRF "
"guard (spec §7.4): the plugin will not follow redirects in-subprocess — "
"the host must re-dispatch the redirect target through the three-way "
"allowlist. Operators can inspect the refused Location target in the audit"
" row (``WEB_FETCH_FIELDS.dlp_scan_result='redirect_refused'``)."

#: src/alfred/plugins/web_fetch/errors.py:102
msgid "web.fetch.error.tls_failure"
msgstr ""
"web.fetch refused: TLS verification failed for {url!r} ({detail}). "
"Production has no operator override; ALFRED_ENV=development is the only "
"escape hatch."

#: src/alfred/plugins/web_fetch/errors.py:117
msgid "web.fetch.error.rate_limited"
msgstr ""
"web.fetch refused: rate limit exceeded for bucket {bucket!r}. Operator "
"can adjust the per-domain / per-user / daily-budget caps in "
"config/policies.yaml under `web_fetch.rate_limits`."

#: src/alfred/plugins/web_fetch/errors.py:130
msgid "web.fetch.error.mime_type_not_allowed"
msgstr ""
"web.fetch refused: response MIME type {mime_type!r} is not allowed. "
"Allowed MIME types are declared in the plugin manifest; operator can "
"narrow via config/policies.yaml `web_fetch.allowed_mime_types`."

#: src/alfred/plugins/web_fetch/errors.py:145
msgid "web.fetch.error.size_limit_exceeded"
msgstr ""
"web.fetch refused: response body {size} bytes exceeds the {limit}-byte "
"limit. Operator can adjust the size cap in config/policies.yaml "
"`web_fetch.size_limit_bytes` (default 5 MiB)."

# sec-pr-s3-5-003 / H3 — host-IP allowlist guard against DNS-rebinding /
# cloud-metadata SSRF. The URL allowlist matches on name; the IP guard
# resolves the hostname and refuses RFC1918 / loopback / link-local /
# multicast / reserved IPs.
# CR-146 major: the caller-visible message intentionally does NOT
# include ``{url}`` or ``{resolved_ip}`` — leaking the resolved IP back
# to the requester turns the refusal into a metadata-IP / RFC1918
# oracle. The audit row still records both fields off
# ``self.url`` / ``self.resolved_ip`` (operator audience). The
# exception's ``reason`` attribute carries the closed-vocabulary refusal
# class (rfc1918 / link_local / loopback / multicast / reserved /
# dns_failure / no_hostname) for audit pivoting.
#: src/alfred/plugins/web_fetch/errors.py:179
msgid "web.fetch.error.internal_ip_refused"
msgstr ""
"web.fetch refused: target resolved to an internal address. Refused to "
"prevent DNS-rebinding / cloud-metadata SSRF against an allowlisted "
"hostname. Operator can review the IP-guard policy in "
"src/alfred/plugins/web_fetch/host_ip_guard.py (spec §7.4); the resolved "
"IP and full URL are recorded on the audit row "
"(``WEB_FETCH_FIELDS.dlp_scan_result='internal_ip_refused'``)."

# C4 / i18n-002 — generic WebFetchError fallback carrying the plugin's
# message string. The plugin-supplied {message} is data (forensic
# attribution), but the operator-facing WebFetchError surface MUST be
# catalogued — wrapping the message in t() lets the carrier string be
# localised while preserving the plugin detail as a placeholder.
#: src/alfred/plugins/web_fetch/fetch_dispatcher.py:612
msgid "web.fetch.error.plugin_returned_message"
msgstr "web.fetch plugin returned an error: {message}"

# C3 / i18n-001 — fetch_dispatcher.py unexpected-dispatch-shape raise.
# The plugin transport returned a result outside the
# (ContentHandle | ControlResult) union — this is a protocol violation
# that surfaces as a typed WebFetchError so the orchestrator's
# operational-error arm catches it. The {shape} placeholder carries the
# Python type name of the offending result (audit-forensic only — not
# the value itself, which could be T3-derived).
#: src/alfred/plugins/web_fetch/fetch_dispatcher.py:659
msgid "web.fetch.error.unexpected_dispatch_shape"
msgstr ""
"web.fetch returned an unexpected dispatch shape ({shape}). Expected "
"ContentHandle on success or ControlResult on plugin-side error; this is a"
" transport-layer protocol violation (spec §7.5)."

# Slice-3 retrospective fix i18n-003 — TlsConfigError raised from
# TlsPolicy.__post_init__ used a raw f-string. The exception bubbles up
# to the operator CLI/TUI when skip_tls_verify is toggled in a non-dev
# environment, so it MUST route through t() per CLAUDE.md i18n hard
# rule #1. {env} carries the offending ALFRED_ENV value so the operator
# can correlate with what the process actually saw.
#: src/alfred/plugins/web_fetch/tls_policy.py:90
msgid "web.fetch.tls.skip_refused_in_non_dev"
msgstr ""
"web_fetch.skip_tls_verify=true is only permitted when "
"ALFRED_ENV=development; current ALFRED_ENV={env!r}. A MITM injecting "
"prompt-injection payloads is the canonical T3 ingestion attack; disabled "
"TLS verification is the bypass (spec §7.11)."

