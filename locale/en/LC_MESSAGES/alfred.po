"registry is in strict mode — register-time enforcement should have "
"prevented this. This is an internal inconsistency; see audit log "
"(correlation_id={correlation_id})."

#: src/alfred/hooks/errors.py:412
msgid "hooks.publisher_drift"
msgstr ""
