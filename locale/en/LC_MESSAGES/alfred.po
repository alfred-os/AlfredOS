#: src/alfred/cli/daemon/__init__.py:81
msgid "daemon.help.root"
msgstr ""
"Boot, stop, and inspect the AlfredOS daemon — the production entrypoint "
"that runs the supervisor and the merged-proposal dispatch loop."

#: src/alfred/cli/daemon/__init__.py:84
msgid "daemon.help.start"
msgstr "Boot the AlfredOS daemon and run it until stopped."

#: src/alfred/cli/daemon/__init__.py:91
msgid "daemon.help.stop"
msgstr "Stop a running AlfredOS daemon (SIGTERM to the PID file's owner)."

# devex-002 closure: the daemon-status help cross-references `alfred status`
# for full instance health, and `status.help` (below) points back here for
# daemon-specific boot details.
#: src/alfred/cli/daemon/__init__.py:98
msgid "daemon.status.help"
msgstr ""
"Show the daemon boot subset: PID, uptime, boot id, and last boot event. "
"For full instance health (providers, budget, gate), see: alfred status"

#: src/alfred/cli/daemon/_commands.py:488
#: src/alfred/cli/daemon/_commands.py:1025
msgid "daemon.boot.comms_adapter_spawn_failed"
msgstr ""
"Comms adapter '{adapter_id}' could not be spawned (missing or malformed "
"manifest). Refusing to boot. Check `plugins/{adapter_id}/manifest.toml` "
"and re-run `alfred daemon start`, or unset it from "
"ALFRED_COMMS_ENABLED_ADAPTERS."

#: src/alfred/cli/daemon/_commands.py:1062
#: src/alfred/cli/daemon/_commands.py:2324
msgid "daemon.boot.comms_promoter_misconfigured"
msgstr ""
"Comms adapter '{adapter_id}' requires host-side sub-payload promotion but"
" no promoter could be built for its kind. Refusing to boot — processing "
"inbound messages without promotion would let raw untrusted sub-payload "
"content reach the privileged orchestrator. This is an internal wiring "
"defect; check `alfred audit log --since 5m` and report it."

#: src/alfred/cli/daemon/_commands.py:1262
msgid "daemon.boot.comms_adapter_handshake_failed"
msgstr ""
"Comms adapter '{adapter_id}' failed its readiness handshake. Refusing to "
"boot. Check `alfred audit log --since 5m` for the adapter's load-refused "
"/ crash row, then re-run `alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:1276
msgid "daemon.comms.adapter_spawned"
msgstr "Comms adapter '{adapter_id}' spawned and ready."

#: src/alfred/cli/daemon/_commands.py:1369
msgid "daemon.boot.comms_socket_bind_failed"
msgstr ""
"Comms adapter '{adapter_id}' could not bind its local socket under "
"`~/.run/alfred/`. Refusing to boot. Check the directory's ownership and "
"permissions (it must be owner-only, mode 0700), remove any stale "
"`comms-*.sock`, then re-run `alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:1446
msgid "gateway.adapter.forwarded_inbound.preview"
msgstr ""
"PREVIEW: the gateway inbound bridge is armed. Forwarded-inbound replay is"
" bounded by the poison ceiling — a deterministically-failing frame is "
"dead-lettered after a small number of attempts. The path is NOT yet flag-"
"day'd into production (G6-7-8); do not depend on it for production "
"inbound."

#: src/alfred/cli/daemon/_commands.py:1506
msgid "daemon.comms.adapter_listening"
msgstr ""
"Comms adapter '{adapter_id}' listening; waiting for `alfred chat` to "
"connect."

# Daemon CLI surface keys added by PR-S4-1 (#174) beyond the PR-S4-0b
# reserve. Operator-facing; all bodies ship real English copy.
#: src/alfred/cli/daemon/_commands.py:1819
msgid "daemon.boot.audit_log_unwritable"
msgstr ""
"The audit log is unwritable, so the daemon refuses to boot — a boot with "
"no audit trail is a silent security failure. Verify Postgres is reachable"
" (`docker compose ps` should show alfred-postgres healthy) and re-run "
"`alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:1861
#: src/alfred/i18n/_slice_4_reserve.py:126
msgid "daemon.lifecycle.ready"
msgstr "Core lifecycle: ready (epoch {epoch})."

#: src/alfred/cli/daemon/_commands.py:1900
#: src/alfred/i18n/_slice_4_reserve.py:127
msgid "daemon.lifecycle.going_down"
msgstr "Core lifecycle: going down (reason: {reason})."

#: src/alfred/cli/daemon/_commands.py:2040
msgid "daemon.boot.environment_unrecognised"
msgstr ""
"ALFRED_ENVIRONMENT={value} is not a recognised environment. Refusing to "
"boot. Use one of: development, production, test (in your .env) and re-run"
" `alfred daemon start`."

# Daemon boot refusals (PR-S4-1; includes round-2 sec-3 closures).
#: src/alfred/cli/daemon/_commands.py:2043
#: src/alfred/i18n/_slice_4_reserve.py:115
msgid "daemon.boot.environment_not_set"
msgstr ""
"Settings.environment is not set. Refusing to boot — production refuses "
"without an explicit environment. Set ALFRED_ENVIRONMENT to one of: "
"development, production, test (in your .env) and re-run `alfred daemon "
"start`."

#: src/alfred/cli/daemon/_commands.py:2094
#: src/alfred/i18n/_slice_4_reserve.py:116
msgid "daemon.boot.unsandboxed_in_production"
msgstr ""
"ALFRED_PLUGIN_LAUNCHER_UNSANDBOXED is set in a production environment. "
"Refusing to boot. Unset the env var (or run in dev) and re-run `alfred "
"daemon start`."

#: src/alfred/cli/daemon/_commands.py:2105
#: src/alfred/i18n/_slice_4_reserve.py:117
msgid "daemon.boot.launcher_not_policy_resolving"
msgstr ""
"bin/alfred-plugin-launcher.sh does not resolve per-plugin policies. "
"Refusing to boot. Re-run `bin/alfred-setup.sh` to refresh the launcher, "
"confirm with `bin/alfred-plugin-launcher.sh --self-test`, then re-run "
"`alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:2121
#: src/alfred/i18n/_slice_4_reserve.py:118
msgid "daemon.boot.snapshot_ref_init_failed"
msgstr ""
"PoliciesSnapshotRef initialisation failed: {detail}. Refusing to boot. "
"Inspect config/policies.yaml for parse errors and re-run `alfred daemon "
"start`."

#: src/alfred/cli/daemon/_commands.py:2135
#: src/alfred/i18n/_slice_4_reserve.py:119
msgid "daemon.boot.capability_gate_handshake_failed"
msgstr ""
"Capability-gate handshake failed: {detail}. Refusing to boot. Check "
"`alfred audit log --since 5m` for grant DB errors, then re-run `alfred "
"daemon start`."

#: src/alfred/cli/daemon/_commands.py:2176
msgid "daemon.boot.boot_infra_install_failed"
msgstr ""
"Seeding the first-party capability gate or installing the boot hook "
"registry failed, so booting is refused. This is a seed/install fault (a "
"Postgres write error or a hookpoint metadata drift), distinct from a "
"grant that seeded but did not project. Check `alfred audit log --since "
"5m` for capability-gate seed or hook-registry errors, then re-run `alfred"
" daemon start`."

#: src/alfred/cli/daemon/_commands.py:2189
msgid "daemon.boot.quarantine_grant_missing"
msgstr ""
"First-party DLP-subscriber grant is not live after boot. The quarantined-"
"extract trust boundary cannot wire its mandatory DLP scan, so booting is "
"refused. Check `alfred audit log --since 5m` for capability-gate seed or "
"grant-load errors, then re-run `alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:2217
msgid "daemon.boot.t3_nonce_registration_failed"
msgstr ""
"The per-process authorised T3 nonce could not be registered (the slot was"
" already set), so booting is refused. A fresh daemon process boots with "
"an empty slot; a non-empty slot means a nonce was already minted (a re-"
"entrant boot, a leaked test, or a duplicate registration). There is no "
"production reset for this slot by design. Check `alfred audit log --since"
" 5m`, ensure only one daemon is starting, then re-run `alfred daemon "
"start`."

#: src/alfred/cli/daemon/_commands.py:2258
msgid "daemon.boot.comms_multi_adapter_unsupported"
msgstr ""
"More than one comms adapter is enabled, which this release does not yet "
"support (their outbound acks would cross-route). Refusing to boot. Set "
"ALFRED_COMMS_ENABLED_ADAPTERS to exactly one adapter and re-run `alfred "
"daemon start`. Multi-adapter support lands in PR-S4-11c (see ADR-0027)."

#: src/alfred/cli/daemon/_commands.py:2307
msgid "daemon.boot.quarantine_child_spawn_failed"
msgstr ""
"The quarantined child could not be spawned. Comms requires the bwrap-"
"sandboxed quarantined child, which needs a Linux host with `bwrap` "
"(bubblewrap) installed and the launcher provisioned. Refusing to boot. On"
" a non-Linux or unprovisioned host, leave ALFRED_COMMS_ENABLED_ADAPTERS "
"unset (comms disabled), or provision bwrap + the plugin launcher and re-"
"run `alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:2474
#: src/alfred/i18n/_slice_4_reserve.py:121
msgid "daemon.boot.started"
msgstr "AlfredOS daemon started ({boot_id})."

#: src/alfred/cli/daemon/_commands.py:2582
msgid "daemon.stop.no_daemon"
msgstr "No AlfredOS daemon is running (no PID file). Nothing to stop."

#: src/alfred/cli/daemon/_commands.py:2585
#: src/alfred/cli/daemon/_commands.py:2590
msgid "daemon.stop.stale_pidfile"
msgstr ""
"The PID file points at a process that is no longer running (stale). "
"Nothing to stop."

#: src/alfred/cli/daemon/_commands.py:2592
#: src/alfred/i18n/_slice_4_reserve.py:128
msgid "daemon.stop.confirmed"
msgstr "AlfredOS daemon stopped (PID {pid})."

#: src/alfred/cli/daemon/_commands.py:2607
msgid "daemon.status.not_running"
msgstr "The AlfredOS daemon is not running. Start it with `alfred daemon start`."

#: src/alfred/cli/daemon/_commands.py:2610
msgid "daemon.status.stale_pidfile"
msgstr ""
"A PID file exists for process {pid}, but that process is no longer "
"running (stale pidfile). The daemon is not running."

#: src/alfred/cli/daemon/_commands.py:2618
#: src/alfred/i18n/_slice_4_reserve.py:129
msgid "daemon.status.template"
msgstr ""
"Daemon PID {pid}\n"
"Started: {started_at}\n"
"Boot ID: {boot_id}\n"
"Last boot completed: {last_boot_at}"

#: src/alfred/cli/daemon/_commands.py:2672
#: src/alfred/cli/daemon/_commands.py:2679
#: src/alfred/cli/daemon/_commands.py:2690
msgid "daemon.status.adapters_unavailable"
msgstr "Adapters: status unavailable"

#: src/alfred/cli/daemon/_commands.py:2694
msgid "daemon.status.adapters_none"
msgstr "Adapters: none reported"

#: src/alfred/cli/daemon/_commands.py:2696
msgid "daemon.status.adapters_header"
msgstr "Adapters:"

#: src/alfred/cli/daemon/_commands.py:2701
msgid "daemon.status.adapter_latest_crash"
msgstr " — last crash: incarnation {seq}, reported by {source}"

#: src/alfred/cli/daemon/_commands.py:2710
msgid "daemon.status.adapter_line"
msgstr ""
"  {adapter_id}: {state} (incarnation {incarnation}, {crashes} crash "
"incident(s)){latest_crash}"

#: src/alfred/cli/gateway/__init__.py:25
msgid "gateway.help.root"
msgstr ""
"Run and inspect the AlfredOS gateway — the resumable front door that "
"stands in for the daemon toward `alfred chat`, surviving a core restart "
"so a session is not torn down by a daemon bounce."

#: src/alfred/cli/gateway/__init__.py:28
msgid "gateway.help.start"
msgstr "Run the gateway process until SIGTERM/SIGINT stops it."

#: src/alfred/cli/gateway/__init__.py:35
msgid "gateway.help.status"
msgstr ""
"Show whether the gateway socket is present and the runtime-dir posture, "
"without dialing it. For full instance health, see: alfred status"

#: src/alfred/cli/gateway/__init__.py:42
msgid "gateway.help.healthcheck"
msgstr ""
"Two-tier liveness/readiness probe for Docker HEALTHCHECK (exit 0 healthy,"
" 1 unhealthy)."

#: src/alfred/cli/gateway/__init__.py:49
msgid "gateway.help.adapters"
msgstr ""
"Show or wait on the status of the gateway-hosted comms adapters (reads "
"the live daemon control plane; does not dial the gateway directly)."

#: src/alfred/cli/gateway/__init__.py:51
msgid "gateway.help.adapters_arg"
msgstr ""
"The adapter to show or wait on (e.g. discord). Omit to show every "
"reported adapter."

#: src/alfred/cli/gateway/__init__.py:53
msgid "gateway.help.adapters_wait"
msgstr ""
"Poll until the named adapter is ready (up) or the timeout elapses; exit 0"
" ready, 1 not-ready, 2 unavailable, 3 unknown adapter."

#: src/alfred/cli/gateway/__init__.py:54
msgid "gateway.help.adapters_timeout"
msgstr "Seconds to wait for readiness before giving up (default 30)."

#: src/alfred/cli/gateway/_adapters.py:159
msgid "gateway.adapters.line"
msgstr "  {adapter}: {state}"

#: src/alfred/cli/gateway/_adapters.py:169
#: src/alfred/cli/gateway/_adapters.py:200
msgid "gateway.adapters.unknown_adapter"
msgstr ""
"Unknown adapter '{adapter}' — it is not reported by the gateway. Check "
"the name and that it is listed in ALFRED_COMMS_ENABLED_ADAPTERS."

#: src/alfred/cli/gateway/_adapters.py:173
msgid "gateway.adapters.none"
msgstr "No gateway-hosted adapters are reported."

#: src/alfred/cli/gateway/_adapters.py:175
msgid "gateway.adapters.header"
msgstr "Gateway adapters:"

#: src/alfred/cli/gateway/_adapters.py:208
#: src/alfred/cli/gateway/_adapters.py:256
msgid "gateway.adapters.unavailable"
msgstr ""
"Cannot read adapter status — the AlfredOS daemon is not reachable. Start "
"it with `alfred daemon start`, then re-run this command."

#: src/alfred/cli/gateway/_adapters.py:213
msgid "gateway.adapters.wait_ready.ready"
msgstr "Adapter '{adapter}' is ready (up)."

#: src/alfred/cli/gateway/_adapters.py:218
