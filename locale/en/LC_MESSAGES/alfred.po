#: src/alfred/bootstrap/gate_factory.py:189
msgid "bootstrap.gate_selected.dev_default"
msgstr ""
"Bootstrap selected RealGate (fail-closed default) for the development "
"environment. Every capability check denies until operator-issued grants "
"land via `alfred plugin grant`. MUST NOT appear on production stacks: "
"production wires RealGate against Postgres, not the in-process stub."

#: src/alfred/bootstrap/quarantine.py:59
msgid "bootstrap.providers_blank_error"
msgstr ""
"Both routing.yaml [quarantine] provider and the privileged provider id "
"must be declared; refusing to boot with either side blank."

#: src/alfred/bootstrap/quarantine.py:63
msgid "bootstrap.providers_same_error"
msgstr ""
"routing.yaml [quarantine] provider must differ from the privileged "
"provider; both are set to {provider}. The dual-LLM split (spec §5.4) "
"requires distinct providers."

#: src/alfred/cli/_bootstrap.py:101
msgid "error.placeholder_api_key"
msgstr ""
"ALFRED_DEEPSEEK_API_KEY is still the placeholder. Edit .env and replace "
"'sk-...' with a real DeepSeek API key."

#: src/alfred/cli/_bootstrap.py:103
msgid "error.config_invalid"
msgstr "configuration is invalid: {detail}"

#: src/alfred/cli/_bootstrap.py:104
msgid "hint.copy_env_example"
msgstr "Tip: copy .env.example to .env and fill in ALFRED_DEEPSEEK_API_KEY."

#: src/alfred/cli/_state_git.py:864
msgid "cli.state_git.error.path_missing"
msgstr ""
"{state_git_path} does not exist. Run `alfred-setup` to initialise the "
"reviewer-gate state repo."

#: src/alfred/cli/_state_git.py:865
msgid "cli.state_git.error.git_missing"
msgstr "`git` is not installed on PATH. Install git and re-run the command."

#: src/alfred/cli/_state_git.py:866
msgid "cli.state_git.error.push_rejected"
msgstr ""
"Reviewer-gate push rejected. Check the alfred structured logs for the "
"`state_git.push_rejected` event (carries the git stderr detail) and the "
"corresponding `*.requested` audit breadcrumb for the operator action that"
" triggered it."

#: src/alfred/cli/_validators.py:114
msgid "cli.validators.plugin_id_invalid"
msgstr ""
"Invalid plugin id {value!r}. Plugin ids are dot-separated segments; each "
"segment must start with a lowercase letter, end with a lowercase letter "
"or digit, and contain only lowercase letters, digits, underscore, or "
"hyphen. No empty, leading, or trailing segments."

#: src/alfred/cli/_validators.py:171
msgid "cli.validators.subscriber_tier_invalid"
msgstr ""
"Invalid subscriber tier {value!r}. Subscriber tiers (the capability axis)"
" must be one of: {valid_tiers}. Note: this is orthogonal to the content "
"trust tier (T0..T3) used by `alfred audit graph --tier`."

#: src/alfred/cli/_validators.py:248
msgid "cli.validators.hookpoint_registry_empty"
msgstr ""
"Cannot validate hookpoint {value!r}: the canonical hookpoint manifest is "
"empty. This is a build-time bug — the static manifest at "
"`src/alfred/hooks/_known_hookpoints.py` should always declare every "
"hookpoint AlfredOS ships. Please report this with the version of the "
"`alfred` CLI you are running."

#: src/alfred/cli/_validators.py:254
msgid "cli.validators.hookpoint_invalid"
msgstr ""
"Unknown hookpoint {value!r}. No publisher has declared a hookpoint by "
"that name. Closest matches: {suggestions}. See "
"`src/alfred/hooks/_known_hookpoints.py` for the canonical list of every "
"hookpoint AlfredOS ships."

#: src/alfred/cli/_validators.py:322 src/alfred/cli/_validators.py:344
#: src/alfred/cli/_validators.py:357
msgid "cli.validators.domain_invalid"
msgstr ""
"Invalid domain {value!r}. Pass a bare lowercase domain (e.g. example.com "
"or api.example.com), no scheme and no path. Allowed shape: lowercase "
"letters, digits, dot, hyphen; must end with a TLD of at least two "
"letters."

#: src/alfred/cli/_validators.py:330
msgid "cli.validators.domain_with_scheme"
msgstr ""
"Refusing domain {value!r}: drop the scheme (http://, https://). The "
"allowlist takes a bare domain; the path component is the separate "
"`--path-prefix` flag."

#: src/alfred/cli/_validators.py:339
msgid "cli.validators.domain_with_path"
msgstr ""
"Refusing domain {value!r}: domain arguments cannot contain `..` or path "
"separators (`/`, `\\`). Pass the bare host; scope the path with the "
"separate `--path-prefix` flag."

#: src/alfred/cli/_validators.py:397
msgid "cli.validators.quarantined_provider_invalid"
msgstr ""
"Invalid quarantined-provider {value!r}. The quarantined provider must be "
"one of the declared provider ids: {valid_providers}."

# PR-S3-6 Component F — alfred audit {log, graph} sub-app. The graph
# subcommand surfaces a swimlane filtered by --tier T1|T2|T3 per spec
# §11.3 ("alfred audit graph --tier T3 --since 24h").
#: src/alfred/cli/audit.py:22
msgid "cli.audit.help"
msgstr "Inspect the audit log; filter the graph swimlane by trust tier."

#: src/alfred/cli/audit.py:177
msgid "cli.audit.graph.since_invalid"
msgstr ""
"Invalid --since value: {value}. Expected a unit-suffixed duration like "
"{example}."

#: src/alfred/cli/audit.py:186
msgid "cli.audit.log.event_help"
msgstr ""
"Restrict to a single event name (e.g. plugin.lifecycle.crashed). Omit to "
"show every event in the time window."

#: src/alfred/cli/audit.py:190 src/alfred/cli/audit.py:246
msgid "cli.audit.graph.since_help"
msgstr "Lookback window (unit-suffixed: 24h, 7d, 30m). Bare integers are rejected."

#: src/alfred/cli/audit.py:194
msgid "cli.audit.log.reason_help"
msgstr ""
"Filter forwarded-inbound drops by reason (unknown_adapter, "
"envelope_body_mismatch, body_malformed, receive_fault, or poisoned). Omit"
" to show every row."

#: src/alfred/cli/audit.py:209 src/alfred/cli/audit.py:273
msgid "cli.audit.backend_unavailable"
msgstr ""
"alfred audit backend not yet wired (PR-S3-7). Until then the storage-"
"layer SQL query is unimplemented; running ``alfred audit log`` / ``alfred"
" audit graph`` cannot return rows. Track the unblock in PR-S3-7."

#: src/alfred/cli/audit.py:224
msgid "cli.audit.log.reason_empty"
msgstr "No audit rows with reason '{reason}' in the last {since}."

#: src/alfred/cli/audit.py:226 src/alfred/cli/audit.py:278
msgid "cli.audit.graph.empty"
msgstr "No audit rows{tier} in the last {since}."

#: src/alfred/cli/audit.py:242
msgid "cli.audit.graph.tier_help"
msgstr ""
"Filter to a single trust-tier swimlane (T0, T1, T2, or T3). Omit to show "
"every tier."

#: src/alfred/cli/audit.py:284
msgid "cli.audit.graph.tier_header"
msgstr "Audit graph — swimlane {tier}"

#: src/alfred/cli/audit.py:286
msgid "cli.audit.graph.header"
msgstr "Audit graph — all tiers"

#: src/alfred/cli/config.py:88
msgid "cli.config.error.read_failed"
msgstr ""
"alfred config refused: {yaml_path} could not be read. OS error: {error}. "
"Check file permissions and rerun the command."

#: src/alfred/cli/config.py:100 src/alfred/cli/config.py:121
#: src/alfred/cli/config.py:246
msgid "cli.config.error.malformed_yaml"
msgstr ""
"alfred config refused: {yaml_path} is malformed and cannot be parsed. "
"YAML error: {error}. Fix the file and rerun the command."

# PR-S3-6 Component D — alfred config sub-app (two-track set/get/list).
# Low-blast keys write to policies.yaml; high-blast keys (e.g.
# quarantined-provider) queue a state.git reviewer-gated proposal.
#: src/alfred/cli/config.py:346
msgid "cli.config.help.group"
msgstr "Get, set, or list operator configuration values."

#: src/alfred/cli/config.py:356
msgid "cli.config.set.help.short"
msgstr "Set an operator configuration key."

#: src/alfred/cli/config.py:360
msgid "cli.config.set.arg.key"
msgstr "Configuration key (e.g. web-fetch-budget, quarantined-provider)."

#: src/alfred/cli/config.py:364
msgid "cli.config.set.arg.value"
msgstr "New value (parsed as int/float when possible, else kept as string)."

#: src/alfred/cli/config.py:443
msgid "cli.config.set.unknown_key"
msgstr ""
"alfred config set refused: '{key}' is not a recognised configuration key."
" Valid keys: {valid_keys}."

#: src/alfred/cli/config.py:455
msgid "cli.config.set.applied"
msgstr "{key} set to {value} in {yaml_path} (hot-reload picks up the change)."

#: src/alfred/cli/config.py:468
msgid "cli.config.get.help.short"
msgstr "Show the current value of an operator configuration key."

#: src/alfred/cli/config.py:472
msgid "cli.config.get.arg.key"
msgstr "Configuration key to read."

#: src/alfred/cli/config.py:493
msgid "cli.config.get.reviewer_gated_set_only"
msgstr ""
"'{key}' is a reviewer-gated (high-blast) configuration key. Its value "
"does not live in policies.yaml — it activates via the proposal flow after"
" `alfred config set {key} <value>` is approved and the supervisor reloads"
" routing.yaml. There is no `alfred config get` surface for reviewer-gated"
" keys in this release."

#: src/alfred/cli/config.py:501
msgid "cli.config.get.unknown_key"
msgstr ""
"alfred config get refused: '{key}' is not a recognised configuration key."
" Valid keys: {valid_keys}."

#: src/alfred/cli/config.py:510
msgid "cli.config.get.not_set"
msgstr ""
"{key} is not set in policies.yaml — the system default applies. Set it "
"with 'alfred config set {key} <value>'."

#: src/alfred/cli/config.py:512
msgid "cli.config.get.value"
msgstr "{key} = {value}"

#: src/alfred/cli/config.py:536
msgid "cli.config.list.help.short"
msgstr "List every operator configuration value from policies.yaml."

#: src/alfred/cli/config.py:545 src/alfred/cli/config.py:549
msgid "cli.config.list.empty"
msgstr ""
"policies.yaml is empty or missing. Run 'alfred config set <key> <value>' "
"to seed the file."

#: src/alfred/cli/config.py:573
msgid "cli.config.set.denied"
msgstr "alfred config set denied: {reason}"

#: src/alfred/cli/config.py:575
msgid "cli.config.set.pending_review"
msgstr ""
"{key} change queued for reviewer approval (high-blast knob).\n"
"  branch:       {branch}\n"
"  proposal_id:  {proposal_id}\n"
"The new value is NOT yet active — it activates when the reviewer approves"
" the proposal and the supervisor reloads its configuration."

