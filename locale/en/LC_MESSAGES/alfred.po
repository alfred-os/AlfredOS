#: src/alfred/cli/plugin.py:520
msgid "cli.plugin.show.arg.plugin_id"
msgstr "Plugin id to inspect."

#: src/alfred/cli/plugin.py:536
msgid "cli.plugin.show.plugin_id_label"
msgstr "plugin_id: {plugin_id}"

#: src/alfred/cli/plugin.py:537
msgid "cli.plugin.show.no_manifest_yet"
msgstr ""
