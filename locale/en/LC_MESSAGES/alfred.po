# #119 — register_hookpoint / register message helpers (Group E + Group F).
#: src/alfred/hooks/errors.py:212
msgid "hooks.hookpoint_drift"
msgstr ""
"hookpoint {name} already declared with different metadata: "
"stored={stored}, new={new}."

#: src/alfred/hooks/errors.py:244
msgid "hooks.unknown_tier"
msgstr ""
"Unknown hook tier {tier} for {subscriber_name} on hookpoint {hookpoint}. "
"Valid tiers: {valid_tiers}."

#: src/alfred/hooks/errors.py:288
msgid "hooks.hookpoint_not_declared.did_you_mean"
msgstr " Did you mean: '{suggestion}'?"

#: src/alfred/hooks/errors.py:290
msgid "hooks.hookpoint_not_declared"
msgstr ""
"hookpoint {name} not declared — the PUBLISHER of this hookpoint must call"
" `register_hookpoint('{name}', ...)` at module init BEFORE any subscriber"
" attempts to register against it. See docs/subsystems/hooks.md → "
"Publisher hello-world.{suggestion}"

#: src/alfred/hooks/errors.py:317
msgid "hooks.tier_not_subscribable"
msgstr ""
"tier {tier} not allowed on hookpoint {hookpoint} — declared "
"subscribable_tiers={subscribable_tiers}."

# #119 CR cycle-2: dispatch-time HookError raises (defense-in-depth path).
#: src/alfred/hooks/errors.py:358
msgid "hooks.dispatch_undeclared_hookpoint"
msgstr ""
"hookpoint {name} dispatched (kind={kind}) but not declared, AND the "
"registry is in strict mode — register-time enforcement should have "
"prevented this. This is an internal inconsistency; see audit log "
"(correlation_id={correlation_id})."

#: src/alfred/hooks/errors.py:412
msgid "hooks.publisher_drift"
msgstr ""
"publisher-side meta drift on hookpoint {name} (drift_kind={drift_kind}): "
"declared subscribable_tiers={declared_subscribable_tiers} "
"refusable_tiers={declared_refusable_tiers} "
"fail_closed={declared_fail_closed}; invoked "
"subscribable_tiers={invoked_subscribable_tiers}, "
"refusable_tiers={invoked_refusable_tiers}, "
"fail_closed={invoked_fail_closed}."

#: src/alfred/hooks/errors.py:457
msgid "hooks.unknown_tier_in_declaration"
msgstr ""
"register_hookpoint({hookpoint}) declares unknown tier(s) {unknown_tiers} "
"— valid tiers are {valid_tiers}. Check for typos on the publisher's "
"subscribable_tiers / refusable_tiers args."

